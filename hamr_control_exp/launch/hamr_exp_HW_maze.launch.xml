<launch>
    <!-- Experimental-stack hardware bringup with Vicon mocap. Infra mirrors
         hamr_bringup/launch/hamr_HW_maze.launch.xml (untouched fallback). -->
    <arg name="controller" default="pid" />
    <arg name="traj" default="smooth" />
    <arg name="metrics" default="true" />
    <arg name="record_bag" default="true" />

    <!-- Tie mocap and odom frames together (same physical origin) -->
    <node pkg="tf2_ros" exec="static_transform_publisher"
          name="static_mocap_to_odom"
          args="0 0 0 0 0 0 mocap odom" />

    <!-- uROS bridge (hardware comms) -->
    <node pkg="hamr_uros_bridge" exec="relay_node" />

    <!-- Bag recording -->
    <node pkg="hamr_bringup" exec="record_hamr_vicon_bag"
          output="screen" if="$(var record_bag)" />

    <!-- Foxglove — connect Studio to ws://ROBOT_IP:8765 -->
    <node pkg="foxglove_bridge" exec="foxglove_bridge" output="screen">
        <param name="port" value="8765" />
        <param name="address" value="0.0.0.0" />
        <param name="send_buffer_limit" value="10000000" />
    </node>

    <!-- Trajectory + controller + metrics selection -->
    <include file="$(find-pkg-share hamr_control_exp)/launch/exp_stack.launch.py">
        <arg name="controller" value="$(var controller)" />
        <arg name="traj" value="$(var traj)" />
        <arg name="metrics" value="$(var metrics)" />
        <arg name="simulating" value="false" />
        <arg name="world_frame" value="mocap" />
    </include>
</launch>
