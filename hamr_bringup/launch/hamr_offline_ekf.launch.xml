<launch>
    <!-- Offline EKF replay: no hardware, no bridge, no controller.
         Run the bag with clock enabled and remap replayed topics into the
         /offline namespace. This keeps live Vicon/robot publishers from
         mixing with replay data when they are still running. -->

    <let name="ekf_config_path"
        value="$(find-pkg-share hamr_bringup)/config/ekf.yaml" />
    <arg name="ekf_config" default="$(var ekf_config_path)" />
    <arg name="wheel_odom_topic" default="/offline/wheel_odom" />
    <arg name="imu_topic" default="/offline/imu/data" />
    <arg name="output_topic" default="/offline/local_HAMR/odom_ekf" />
    <arg name="tf_topic" default="/offline/tf" />
    <arg name="tf_static_topic" default="/offline/tf_static" />

    <!-- imu_link -> base_link identity TF same as live launch.
         The bag also contains /tf_static with this transform, but publishing it
         here ensures the EKF has it before the first /imu/data message arrives. -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="offline_imu_link_static_tf"
          args="--x 0.0 --y 0.0 --z 0.0 --roll 0.0 --pitch 0.0 --yaw 0.0 --frame-id base_link --child-frame-id imu_link">
        <remap from="/tf_static" to="$(var tf_static_topic)"/>
    </node>

    <!-- EKF node: identical config to the live run, with sim time so the bag
         clock drives processing instead of wall time.
         Inputs, output, and TF are remapped away from live topic names. -->
    <node pkg="robot_localization" exec="ekf_node" name="ekf_filter_node_offline" output="screen">
        <param from="$(var ekf_config)"/>
        <param name="use_sim_time" value="true"/>
        <remap from="/wheel_odom" to="$(var wheel_odom_topic)"/>
        <remap from="/imu/data" to="$(var imu_topic)"/>
        <remap from="/tf" to="$(var tf_topic)"/>
        <remap from="/tf_static" to="$(var tf_static_topic)"/>
        <remap from="odometry/filtered" to="$(var output_topic)"/>
    </node>
</launch>
