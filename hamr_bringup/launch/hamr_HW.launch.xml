<launch>
    <!-- Path Variables -->
    <let name="urdf_path" 
        value="$(find-pkg-share hamr_description)/urdf/hamr.urdf.xacro" />

    <let name="rviz_config_path" 
        value="$(find-pkg-share hamr_description)/rviz/HW_urdf_config.rviz" />

    <let name="pid_config_path"
        value="$(find-pkg-share hamr_bringup)/config/hamr_hw_control_params.yaml" />

    <arg name="record_bag" default="false" />

    <!-- HAMR Controller -->
    <node pkg="hamr_control" exec="hamr_controller" output="screen">
        <param from="$(var pid_config_path)" />
    </node>

    <!-- Waypoint Reference Trajectory Publisher -->
    <node pkg="reference_trajectory" exec="waypoint_traj_sequence" output="screen">
        <param name="odom_topic" value="/HAMR_base/odom" />
        <param name="reference_topic" value="/reference_trajectory" />
        <param name="frame_id" value="odom" />

        <!-- Increase while debugging so it actually switches waypoints -->
        <param name="position_tolerance" value="0.20" />

        <!-- Keep false while only testing base movement -->
        <param name="require_yaw_goal" value="false" />

        <param name="publish_rate_hz" value="50.0" />
        <param name="debug_rate_hz" value="5.0" />
    </node>

    <!-- Record Vicon/controller topics for post-run analysis -->
    <node pkg="hamr_bringup" exec="record_hamr_vicon_bag"
          output="screen" if="$(var record_bag)" />

    <!-- Micro-ROS bridge -->
    <node pkg="hamr_uros_bridge" exec="relay_node" output="screen" />

    <!-- Foxglove bridge — connect Studio to ws://PI_IP:8765 -->
    <node pkg="foxglove_bridge" exec="foxglove_bridge" output="screen">
        <param name="port" value="8765" />
        <param name="address" value="0.0.0.0" />
        <param name="send_buffer_limit" value="10000000" />
    </node>
</launch>