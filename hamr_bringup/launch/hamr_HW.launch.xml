<launch>
    <!-- Path Variables -->
    <let name="urdf_path"
        value="$(find-pkg-share hamr_description)/urdf/hamr.urdf.xacro" />
    <let name="rviz_config_path"
        value="$(find-pkg-share hamr_description)/rviz/HW_urdf_config.rviz" />
    <let name="pid_config_path"
        value="$(find-pkg-share hamr_bringup)/config/hamr_hw_control_params.yaml" />
    <let name="ekf_config_path"
        value="$(find-pkg-share hamr_bringup)/config/ekf.yaml" />
    <let name="ekf_mag_config_path"
        value="$(find-pkg-share hamr_bringup)/config/ekf_mag.yaml" />
    <let name="bridge_config_path"
        value="$(find-pkg-share hamr_bringup)/config/hamr_uros_bridge.yaml" />
    <arg name="record_bag" default="true" />
    <arg name="use_mag" default="true" />

    
    <!-- To launch the URDF Robot State Publisher -->
    <!-- <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" 
            value="$(command 'xacro $(var urdf_path)')" />
    </node>  -->

    <!-- Launch Rviz with the configuration -->
    <!-- <node pkg="rviz2" exec="rviz2" output="screen"
          args="-d $(var rviz_config_path)" /> -->

    <!-- Launch HAMR Controller -->
    <node pkg="hamr_control" exec="hamr_controller" >
        <param from="$(var pid_config_path)" />
    </node>

    <!-- Graphing -->
    <!-- <node pkg="hamr_control" exec="hamr_pid_graph" />
    <node pkg="hamr_control" exec="hamr_odom_graph"/>
    <node pkg="hamr_control_cpp" exec="hamr_path_tracer" /> -->

    <!-- Wheel odometry: integrates encoder ticks → /wheel_odom
         publish_tf is false because the EKF below owns the odom→base_link TF -->
    <node pkg="hamr_odometry" exec="holonomic_odom_node" output="screen">
        <param name="publish_tf" value="false"/>
        <param name="r_wheel" value="0.1250"/>
        <param name="a_wheel" value="0.350"/>
        <param name="b_wheel" value="0.45"/>
        <param name="base_yaw_offset" value="1.57079632679"/>
        <param name="yaw_sign" value="-1.0"/>
        <param name="left_tick_scale" value="1.02"/>
        <param name="right_tick_scale" value="0.9"/>
        <param name="ticks_per_rev" value="4526.4"/>
    </node>

    <!-- IMU mounting TF: BNO055 is mounted flat and axis-aligned with base_link
         (X forward, Z up), so imu_link → base_link is identity. The EKF needs this
         transform to rotate /imu/data into base_link; without it every IMU message
         is rejected. Replace the offsets here if the IMU is ever remounted. -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="imu_link_static_tf"
          args="--x 0.0 --y 0.0 --z 0.0 --roll 0.0 --pitch 0.0 --yaw 0.0 --frame-id base_link --child-frame-id imu_link" />

    <!-- EKF: fuses /wheel_odom + /imu/data into /local_HAMR/odom and owns odom→base_link TF.
         use_mag:=false (default) -> ekf.yaml      (gyro yaw-rate only, known good)
         use_mag:=true            -> ekf_mag.yaml  (adds BNO055 absolute-yaw / magnetometer) -->
    <node pkg="robot_localization" exec="ekf_node" name="ekf_filter_node" output="screen"
          unless="$(var use_mag)">
        <param from="$(var ekf_config_path)"/>
        <remap from="odometry/filtered" to="local_HAMR/odom"/>
    </node>
    <node pkg="robot_localization" exec="ekf_node" name="ekf_filter_node" output="screen"
          if="$(var use_mag)">
        <param from="$(var ekf_mag_config_path)"/>
        <remap from="odometry/filtered" to="local_HAMR/odom"/>
    </node>

    <!-- uROS bridge — serial_port/baud configured in hamr_uros_bridge.yaml
         ESP USB-CDC (logs) is /dev/ttyACM0 @ 115200.
         Serial0 data UART is typically /dev/ttyUSB0 @ 460800 — verify with: ls /dev/ttyUSB* -->
    <node pkg="hamr_uros_bridge" exec="relay_node">
        <param from="$(var bridge_config_path)" />
    </node>

    <!-- Waypoint trajectory publisher — loops the hardcoded path in waypoint_traj_simple.py -->
    <!-- <node pkg="reference_trajectory" exec="waypoint_traj_simple" output="screen" /> -->

    <!-- Record Vicon, onboard localization, commands, and encoder ticks for offline comparison. -->
    <node pkg="hamr_bringup" exec="record_hamr_test_bag"
          output="screen" if="$(var record_bag)" />

    <!-- Foxglove WebSocket bridge — connect Foxglove Studio to ws://<robot-ip>:8765 -->
    <node pkg="foxglove_bridge" exec="foxglove_bridge" name="foxglove_bridge">
        <param name="port" value="8765" />
    </node>

</launch>
