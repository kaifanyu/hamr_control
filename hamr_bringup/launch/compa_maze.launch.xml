<launch>
    <let name="xacro_path" 
        value="$(find-pkg-share compa_description)/urdf/compa.urdf.xacro"/>
    <let name="sdf_path"   
        value="$(find-pkg-share compa_description)/urdf/compa.sdf"/>
    <let name="gazebo_config_path"
        value="$(find-pkg-share hamr_bringup)/config/gazebo_bridge_compa.yaml" />
    <let name="rviz_config_path" 
        value="$(find-pkg-share hamr_description)/rviz/urdf_config.rviz" />
    <let name="pid_config_path"
        value="$(find-pkg-share hamr_bringup)/config/compa_pid_params.yaml" />

    <!-- Robot Spawn Properties -->
    <let name="spawn_x"   value="-13.5"/>
    <let name="spawn_y"   value="-13.5"/>
    <let name="spawn_z"   value="0.1"/>
    <let name="spawn_roll"  value="0.0"/>
    <let name="spawn_pitch" value="0.0"/>
    <let name="spawn_yaw"   value="-3.14159"/>
    <let name="robot_name"  value="compa"/>


    <!-- To launch GZ -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <!-- <arg name="gz_args" value="empty.sdf -r" /> -->
        <arg name="gz_args" value="$(find-pkg-share hamr_bringup)/worlds/2.5D_maze.sdf -r" />
    </include>
    
    <!-- To spawn the robot in GZ from the URDF generated by this robot_description topic -->
    <!-- <node pkg="ros_gz_sim" exec="create" args="-name compa -file $(var sdf_path)" /> -->
    <node pkg="ros_gz_sim" exec="create" output="screen"
      args="-topic robot_description
            -x $(var spawn_x) -y $(var spawn_y) -z $(var spawn_z)
            -R $(var spawn_roll) -P $(var spawn_pitch) -Y $(var spawn_yaw)" />

    <!-- To launch the URDF Robot State Publisher -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <!-- <param name="use_sim_time" value="true"/> -->
        <param name="robot_description" 
            value="$(command 'xacro $(var xacro_path)')" />
    </node> 

    <!-- To bridge ros and upload the config file to bridge topic by topic -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <!-- Launch Rviz with the configuration -->
    <node pkg="rviz2" exec="rviz2" output="screen"
          args="-d $(var rviz_config_path)" />

    <node pkg="tf2_ros" exec="static_transform_publisher"
        name="static_map_to_odom" output="screen"
        args="0 0 0 0 0 0 map odom"/>

    <!-- <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" /> -->

    <!-- Launch COMPA Controller -->
    <node pkg="compa_control_py" exec="compa_controller" >
        <param from="$(var pid_config_path)" />
    </node>
    <!-- <node pkg="compa_control_py" exec="compa_pid_graph" /> -->
    <!-- <node pkg="compa_control_py" exec="compa_odom_graph"> -->
        <!-- <param name="use_sim_time" value="true" /> -->
    <!-- </node> -->


    <node pkg="hamr_control_cpp" exec="compa_path_tracer" />
    <node pkg="hamr_control_cpp" exec="cost_map_publisher">
        <param name="map_width_m" value="60.0" />
        <param name="map_length_m" value="60.0" />
        <param name="map_height_m" value="1.5" />
        <param name="image_path" value="$(find-pkg-share hamr_bringup)/terrain_assets/heightmaps/hamr_maze_big_slight_offroad.png" />
    </node>
    <node pkg="compa_control_py" exec="tf_trail_node" />

    <node pkg="reference_trajectory" exec="waypoint_traj" />

    <!-- MAP, PRM ASTAR and TRACER -->
    <node pkg="hamr_control_cpp" exec="map_publisher" />
    <node pkg="hamr_control_cpp" exec="astar_search" />
    <node pkg="hamr_control_cpp" exec="prm_builder">
        <param name="samples" value="10000" />
        <param name="k_neighbors" value="6" />
        <param name="inflation_radius_m" value="0.75" />
    </node>
    <node pkg="hamr_control_cpp" exec="hamr_path_tracer" />
    <node pkg="hamr_uros_bridge" exec="relay_node" />

</launch>