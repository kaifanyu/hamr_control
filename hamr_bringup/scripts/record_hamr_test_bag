#!/usr/bin/env bash
set -euo pipefail

USER_ARGS=()
for arg in "$@"; do
  if [[ "${arg}" == "--ros-args" ]]; then
    break
  fi
  USER_ARGS+=("${arg}")
done

RUN_NAME="${USER_ARGS[0]:-${HAMR_BAG_NAME:-hamr_hw_$(date +%Y%m%d_%H%M%S)}}"
BAG_ROOT="${HAMR_BAG_ROOT:-${HOME}/hamster_ws/src/hamr_control/rosbags}"
BAG_DIR="${USER_ARGS[1]:-${BAG_ROOT}/${RUN_NAME}}"
STORAGE_ID="${STORAGE_ID:-${HAMR_BAG_STORAGE_ID:-mcap}}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QOS_PROFILE_OVERRIDES_PATH="${HAMR_BAG_QOS_OVERRIDES:-}"

if [[ -z "${QOS_PROFILE_OVERRIDES_PATH}" && -f "${SCRIPT_DIR}/../config/record_qos.yaml" ]]; then
  QOS_PROFILE_OVERRIDES_PATH="${SCRIPT_DIR}/../config/record_qos.yaml"
elif [[ -z "${QOS_PROFILE_OVERRIDES_PATH}" ]] && command -v ros2 >/dev/null 2>&1; then
  PACKAGE_PREFIX="$(ros2 pkg prefix hamr_bringup 2>/dev/null || true)"
  if [[ -n "${PACKAGE_PREFIX}" && -f "${PACKAGE_PREFIX}/share/hamr_bringup/config/record_qos.yaml" ]]; then
    QOS_PROFILE_OVERRIDES_PATH="${PACKAGE_PREFIX}/share/hamr_bringup/config/record_qos.yaml"
  fi
fi

QOS_ARGS=()
if [[ -n "${QOS_PROFILE_OVERRIDES_PATH}" ]]; then
  QOS_ARGS=(--qos-profile-overrides-path "${QOS_PROFILE_OVERRIDES_PATH}")
fi

TOPIC_REGEX='^/(HAMR_base|HAMR_turret)/(odom|pose|individual_marker_array)$|^/(local_HAMR/odom|wheel_odom|imu/data|imu/data_raw|imu/mag|imu/calib_status|tf|tf_static)$|^/(reference_trajectory|waypoints_path|state_error|live_gains)$|^/(left_wheel|right_wheel|turret)/cmd_vel$|^/(left_wheel|right_wheel|turret)/encoder_ticks$|^/(robot_pose|odom|cmd_vel)$'

mkdir -p "$(dirname "${BAG_DIR}")"

echo "Recording HAMR localization test bag:"
echo "  output:  ${BAG_DIR}"
echo "  storage: ${STORAGE_ID}"
echo "  regex:   ${TOPIC_REGEX}"
if [[ -n "${QOS_PROFILE_OVERRIDES_PATH}" ]]; then
  echo "  qos:     ${QOS_PROFILE_OVERRIDES_PATH}"
fi

exec ros2 bag record \
  --storage "${STORAGE_ID}" \
  --output "${BAG_DIR}" \
  "${QOS_ARGS[@]}" \
  --regex "${TOPIC_REGEX}"
