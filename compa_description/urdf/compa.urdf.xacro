<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
  name="compa">
  
  <!-- To import ball joint, camera and more -->
  <xacro:include filename="common_properties.urdf.xacro" /> 
  <!-- <xacro:include filename="camera.urdf.xacro" /> -->
  <xacro:include filename="compa_gazebo.urdf.xacro" /> 

  <!-- Base -->
  <link name="base_footprint" />

  <joint name="base_joint" type="fixed">
      <parent link="base_footprint" />
      <child link="base_link" />
      <origin xyz="0 0 0.25042" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <xacro:box_inertia m="4.77" x="0.45" y="0.45" z="0.05"
                    o_xyz="0 0 0" o_rpy="0 0 ${-pi/2}" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 ${-pi/2}" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 ${-pi/2}" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/base_link.STL" /> -->
        <box size="0.45 0.45 0.05"/>
      </geometry>
    </collision>
  </link>


  <!-- Left Rocker -->
  <link name="left_rocker_link">
    <!-- <inertial>
      <origin
        xyz="0.10635785885848 -0.0822265512946505 -0.0953433649729512"
        rpy="0 0 0" />
      <mass
        value="4.36949644437113" />
      <inertia
        ixx="0.00932322040257303"
        ixy="0.000840455697953046"
        ixz="-0.00990088926719093"
        iyy="0.100262669486419"
        iyz="0.000224119901626131"
        izz="0.0927291914231702" />
    </inertial> -->
    <xacro:box_inertia m="4.36949644437113" x="0.6" y="0.037" z="0.05"
                    o_xyz="0 -0.072 -0.021" o_rpy="0 0 0" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/left_rocker_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 -0.072 -0.021"
        rpy="0 0 0" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/left_rocker_link.STL" /> -->
        <box size="0.6 0.037 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_left_rocker_joint"
    type="continuous">
    <origin
      xyz="0 0.184999999999999 0.0360999999999991"
      rpy="0 0 ${-pi}" />
    <parent
      link="base_link" />
    <child
      link="left_rocker_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <link name="left_wheel_link">
    <!-- <inertial>
      <origin
        xyz="0.000774305945393738 0.0975714857383374 -2.37966814073398E-07"
        rpy="0 0 0" />
      <mass
        value="20.74378098590227" />
      <inertia
        ixx="0.00876644391195367"
        ixy="-5.31179573172881E-07"
        ixz="5.28913139433932E-08"
        iyy="0.014659876055652"
        iyz="3.15796027624797E-08"
        izz="0.00876696237942707" />
    </inertial> -->
    <xacro:cylinder_inertia m="20.74378098590227" r="0.1075" h="0.083"
                        o_xyz="0 0 0"
                        o_rpy="${pi/2} 0 0" />
    <visual>
      <origin
        xyz="-0.001 -0.098 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/left_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.298039215686275 0.298039215686275 0.298039215686275 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="${pi/2} 0 0" />
      <geometry>
        <cylinder radius="0.1075" length="0.083" />
      </geometry>
    </collision>
  </link>

  <joint name="left_rocker_left_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.27114 -0.14572 -0.1442"
      rpy="3.1416 0 0" />
    <parent
      link="left_rocker_link" />
    <child
      link="left_wheel_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <link name="left_caster_wheel_link">
    <xacro:cylinder_inertia m="5.0" r="0.087" h="0.05"
                        o_xyz="0 0 0" o_rpy="${pi/2} 0 0" />
    <collision>
      <origin
        xyz="0 0 0"
        rpy="${pi/2} 0 0" />
      <geometry>
        <cylinder radius="0.087" length="0.05" />
      </geometry>
    </collision>
  </link>

  <joint name="left_rocker_left_caster_wheel_joint"
    type="continuous">
    <origin
      xyz="0.315 -0.10422 -0.1647"
      rpy="3.1416 0 0" />
    <parent
      link="left_rocker_link" />
    <child
      link="left_caster_wheel_link" />
    <axis
      xyz="0 1 0" />
  </joint>


  <!-- Right Rocker -->
  <link name="right_rocker_link">
    <!-- <inertial>
      <origin
        xyz="0.106539267968694 0.0826305372124516 -0.0953304868043567"
        rpy="0 0 0" />
      <mass
        value="4.36946919822567" />
      <inertia
