        iyy="0.014659876055652"
        iyz="3.1579602755194E-08"
        izz="0.00876696237942706" />
    </inertial> -->    
    <xacro:cylinder_inertia m="20.74378098590227" r="0.1075" h="0.083"
                        o_xyz="0 0 0"
                        o_rpy="${pi/2} 0 0" />
    <visual>
      <origin
        xyz="-0.001 0.098 0"
        rpy="0 0 ${pi}" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/right_wheel_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.298039215686275 0.298039215686275 0.298039215686275 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="${pi/2} 0 0" />
      <geometry>
        <cylinder radius="0.1075" length="0.083" />
      </geometry>
    </collision>
  </link>

  <joint name="right_rocker_right_wheel_joint"
    type="continuous">
    <origin
      xyz="-0.27114 0.14572 -0.1442"
      rpy="0 0 ${pi}" />
    <parent
      link="right_rocker_link" />
    <child
      link="right_wheel_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <link name="right_caster_wheel_link">
    <xacro:cylinder_inertia m="5.0" r="0.087" h="0.05"
