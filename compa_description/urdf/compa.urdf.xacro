      rpy="3.1416 0 0" />
    <parent
      link="right_rocker_link" />
    <child
      link="right_caster_wheel_link" />
    <axis
      xyz="0 1 0" />
  </joint>


  <!-- Gimbal -->
  <link name="roll_link">
    <xacro:box_inertia m="0.944517139921142" x="0.35" y="0.35" z="0.05"
                    o_xyz="0 0 0" o_rpy="0 0 0" />
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/roll_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/roll_link.STL" /> -->
        <box size="0.35 0.35 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_roll_joint"
    type="continuous">
    <origin
      xyz="0 0 0.03826"
      rpy="${-pi} 0 0" />
    <parent
      link="base_link" />
    <child
      link="roll_link" />
    <axis
      xyz="-1 0 0" />
  </joint>

  <link name="pitch_link">
    <inertial>
      <origin
        xyz="-1.53612491524818E-06 0.0452818711897623 -0.00479118208676022"
        rpy="0 0 0" />
      <mass
        value="0.373399633584383" />
      <inertia
        ixx="0.000245121023174029"
        ixy="-1.04461141223475E-09"
        ixz="-5.02589593844006E-10"
        iyy="0.000177685960624184"
        iyz="-2.52895140798418E-05"
        izz="0.000294726650760256" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/pitch_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/pitch_link.STL" /> -->
        <box size="0.07 0.3 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="roll_pitch_joint"
    type="continuous">
    <origin
      xyz="0.0035 0 0"
      rpy="3.1416 0 ${pi}" />
    <parent
      link="roll_link" />
    <child
      link="pitch_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <link name="yaw_plate_link">
    <inertial>
      <origin
        xyz="-0.00447913610788967 2.41196326362311E-05 -0.127371508973676"
        rpy="0 0 0" />
      <mass
        value="4.77359574593992" />
      <inertia
        ixx="0.137280882823545"
        ixy="2.12673978923993E-05"
        ixz="0.000121233585196392"
        iyy="0.141251293392401"
        iyz="-6.47537750501791E-07"
        izz="0.27812043683305" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="${pi} 0 ${pi}" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/yaw_plate_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 -0.127371508973676"
        rpy="${pi} 0 ${pi}" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/yaw_plate_link.STL" /> -->
        <cylinder radius="0.4" length="0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="pitch_yaw_plate_joint"
    type="continuous">
    <origin
      xyz="0 0 0.0375"
      rpy="${pi} 0 ${pi}" />
    <parent
      link="pitch_link" />
    <child
      link="yaw_plate_link" />
    <axis
      xyz="0 0 -1" />
  </joint>

  <!-- Dummy link to visualize yaw axis -->
  <link name="yaw_dummy_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual name="yaw_dummy_visual">
      <geometry>
        <sphere radius="0.001"/>
      </geometry>
    </visual>

    <collision name="yaw_dummy_collision">
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="yaw_plate_fixed_joint" type="revolute">
    <origin xyz="0 0 0.075" rpy="${pi} 0 0"/>
    <parent link="yaw_plate_link"/>
    <child  link="yaw_dummy_link"/>
    <axis xyz="0 0 1"/>
    <!-- Lock at 0 lower=upper=0; add large effort + damping so it stays put -->
    <limit lower="0" upper="0" effort="1e6" velocity="0"/>
    <dynamics damping="100" friction="1.0"/>
  </joint>



  <!-- ROCKER LINKS -->
  <link name="leverage_link">
    <inertial>
      <origin
        xyz="-0.0117745961443602 -3.98443129349599E-08 -0.000252346332911095"
        rpy="0 0 0" />
      <mass
        value="0.16962532718169" />
      <inertia
        ixx="0.00130897914050679"
        ixy="3.29957052469139E-12"
        ixz="-4.97883603410576E-09"
        iyy="5.88902413778525E-05"
        iyz="5.89893406244419E-11"
        izz="0.00125385800443425" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://compa_description/meshes/leverage_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.866666666666667 0.909803921568627 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/leverage_link.STL" /> -->
        <box size="0.01 0.45 0.07"/>
      </geometry>
    </collision>
  </link>


  <joint name="base_leverage_joint"
    type="revolute">
    <origin
      xyz="0.2332 0 0.03826"
      rpy="0 0 ${-pi}" />
    <parent
      link="base_link" />
    <child
      link="leverage_link" />
    <axis
      xyz="-1 0 0" />
    <limit effort="20" velocity="1.0" lower="${-pi/12}" upper="${pi/12}"/>
  </joint>

