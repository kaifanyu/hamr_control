        rpy="0 0 0" />
      <geometry>
        <!-- <mesh
          filename="package://compa_description/meshes/right_rocker_link.STL" /> -->
        <box size="0.6 0.037 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_right_rocker_joint"
    type="continuous">
    <origin
      xyz="0 -0.185 0.0361"
      rpy="0 0 ${-pi}" />
    <parent
      link="base_link" />
    <child
      link="right_rocker_link" />
    <axis
      xyz="0 1 0" />
  </joint>

  <link name="right_wheel_link">
    <!-- <inertial>
      <origin
        xyz="0.000774305945394016 0.0975714857383375 -2.37966814281565E-07"
        rpy="0 0 0" />
      <mass
        value="20.74378098590227" />
      <inertia
